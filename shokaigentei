.worry-tag{font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.2em;color:var(--gold3)}
.worry-card p{font-size:12px;color:var(--text2);line-height:1.8;margin-top:8px}

/* 料金 / ファイル */
.plan-grid{display:flex;flex-direction:column;gap:16px;max-width:520px;margin:0 auto}
.plan{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);position:relative;overflow:hidden}
.plan.featured{border:1px solid var(--border2);box-shadow:0 0 30px rgba(201,168,76,0.08)}
.plan::before{content:'';position:absolute;top:0;right:0;width:120px;height:120px;background:radial-gradient(circle at top right,rgba(201,168,76,0.06) 0%,transparent 70%);pointer-events:none}
.plan-head{display:flex;justify-content:space-between;align-items:center;padding:10px 18px;border-bottom:1px solid var(--border);background:rgba(0,0,0,0.25);font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.18em;color:var(--text4)}
.plan-head .dots{display:flex;gap:5px}
.plan-head .dots i{width:7px;height:7px;border-radius:50%;display:block}
.plan-body{padding:1.5rem 1.5rem 1.6rem}
.plan-badge{display:inline-block;font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.18em;padding:4px 12px;border-radius:20px;margin-bottom:0.9rem}
.badge-std{border:1px solid var(--gold);color:var(--gold)}
.badge-plus{background:linear-gradient(135deg,var(--gold3),var(--gold) 50%,var(--gold2));color:#1a0f00;font-weight:700}
.plan-name{font-family:'Noto Serif JP',serif;font-size:1.25rem;font-weight:700;color:var(--text);margin-bottom:2px}
.plan-en{font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.18em;color:var(--text4);margin-bottom:1.1rem}
.plan-price{display:flex;align-items:baseline;gap:4px;margin-bottom:2px}
.plan-price .yen{font-size:16px;color:var(--text3)}
.plan-price .num{font-family:'Cinzel',serif;font-size:2.6rem;line-height:1;color:var(--gold2);font-weight:700}
.plan-price .man{font-size:15px;color:var(--text3)}
.plan-note{font-size:10px;color:var(--text4);letter-spacing:0.05em;margin-bottom:1.1rem}
.plan-spec{list-style:none;border-top:1px solid rgba(201,168,76,0.12)}
.plan-spec li{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(201,168,76,0.08);font-size:12px}
.plan-spec li .k{color:var(--text3)}
.plan-spec li .k::before{content:'✦ ';color:var(--gold3);font-size:9px}
.plan-spec li .v{color:var(--text);font-weight:500}
.plan-spec li .v.dim{color:var(--text4);font-weight:400}
.plan-line-btn{display:flex;align-items:center;justify-content:center;gap:8px;margin-top:1.2rem;background:var(--line);color:#fff;font-weight:700;font-size:13px;padding:12px;border-radius:30px;text-decoration:none;letter-spacing:0.05em;box-shadow:0 4px 16px rgba(6,199,85,0.22)}
.plan-line-btn.alt{background:transparent;border:1px solid rgba(6,199,85,0.5);color:#06C755;box-shadow:none}
.fee-note{max-width:520px;margin:1.6rem auto 0;text-align:center;font-size:10px;color:var(--text4);line-height:1.9}
.fee-note b{color:var(--gold)}

/* LINE 大型カード */
.line-section{padding:1.5rem 1.25rem}
.line-card{background:linear-gradient(135deg,#041a0a,#051f0e);border:1px solid rgba(6,199,85,0.25);border-radius:var(--radius);padding:2rem 1.5rem;text-align:center;position:relative;overflow:hidden;max-width:560px;margin:0 auto}
.line-card::before{content:'';position:absolute;top:-50px;left:50%;transform:translateX(-50%);width:240px;height:240px;background:radial-gradient(circle,rgba(6,199,85,0.1) 0%,transparent 70%);pointer-events:none}
.line-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(6,199,85,0.1);border:1px solid rgba(6,199,85,0.3);border-radius:20px;padding:4px 14px;margin-bottom:0.9rem;font-size:10px;color:#06C755;letter-spacing:0.1em}
.line-title{font-family:'Noto Serif JP',serif;font-size:1.05rem;font-weight:700;color:#e8ffe8;margin-bottom:0.5rem;line-height:1.7}
.line-sub{font-size:11px;color:rgba(6,199,85,0.6);margin-bottom:1.3rem;line-height:1.9}
.line-steps{list-style:none;max-width:300px;margin:0 auto 1.4rem;text-align:left}
.line-steps li{display:flex;gap:10px;align-items:flex-start;padding:7px 0;font-size:12px;color:var(--text2)}
.line-steps li .s{color:#06C755;font-family:'Cinzel',serif;font-size:11px;flex:0 0 auto}
.btn-line{display:inline-flex;align-items:center;gap:8px;background:var(--line);color:#fff;font-weight:700;font-size:14px;padding:14px 2.2rem;border-radius:30px;text-decoration:none;letter-spacing:0.05em;box-shadow:0 4px 16px rgba(6,199,85,0.25);position:relative;z-index:10;cursor:pointer}
.line-note{font-size:10px;color:rgba(6,199,85,0.35);margin-top:0.7rem}

/* 流れ */
.flow{max-width:560px;margin:0 auto;position:relative}
.flow::before{content:'';position:absolute;left:17px;top:14px;bottom:14px;width:1px;background:linear-gradient(var(--gold),rgba(201,168,76,0.1))}
.flow-step{display:flex;gap:18px;padding:0.7rem 0;position:relative}
.flow-num{flex:0 0 36px;height:36px;border-radius:50%;background:var(--bg);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-size:12px;color:var(--gold2);z-index:2;font-weight:700}
.flow-txt h4{font-family:'Noto Serif JP',serif;font-size:14px;font-weight:700;color:var(--text);margin-bottom:3px}
.flow-txt p{font-size:11px;color:var(--text3);line-height:1.8}

/* 比較表 */
.price-wrap{overflow-x:auto;max-width:560px;margin:0 auto}
.price-table{width:100%;border-collapse:collapse;font-size:12px;min-width:380px}
.price-table th{background:var(--bg4);color:var(--gold);font-weight:500;padding:11px 12px;text-align:center;border-bottom:1px solid var(--border);font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.1em}
.price-table th.label{text-align:left}
.price-table td{padding:11px 12px;border-bottom:1px solid rgba(201,168,76,0.08);color:var(--text2);text-align:center}
.price-table td.label{text-align:left;color:var(--text3)}
.price-check{color:var(--gold2)}.price-x{color:var(--text4)}

/* FAQ */
.faq-wrap{max-width:680px;margin:0 auto}
.faq-item{border-bottom:1px solid rgba(201,168,76,0.1);cursor:pointer}
.faq-q{padding:1.1rem 0;font-size:13px;color:var(--text);display:flex;justify-content:space-between;align-items:center;gap:12px;font-weight:500;line-height:1.6}
.faq-q-icon{width:24px;height:24px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--gold3);font-size:14px;transition:transform 0.3s,background 0.3s}
.faq-q-icon.open{transform:rotate(180deg);background:rgba(201,168,76,0.1)}
.faq-a{font-size:12px;color:var(--text2);line-height:2;padding-bottom:1rem;display:none}
.faq-a.open{display:block}

/* 最終CTA banner */
.consult-banner{background:linear-gradient(135deg,#1a0f08,#0d1508,#1a0f08);border:1px solid var(--border);border-radius:var(--radius);padding:2rem 1.5rem;text-align:center;position:relative;overflow:hidden;margin:0 1.25rem}
.consult-banner::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(201,168,76,0.05) 0%,transparent 70%);pointer-events:none}
.consult-title{font-family:'Noto Serif JP',serif;font-size:1.1rem;color:var(--text);margin-bottom:0.5rem;font-weight:700;position:relative;z-index:2}
.consult-sub{font-size:11px;color:var(--text2);line-height:2;margin-bottom:1.5rem;position:relative;z-index:2}
.consult-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;position:relative;z-index:2}

/* SNS / footer */
.sns-block{background:var(--bg);padding:1.5rem 1.25rem 0.5rem;text-align:center}
.sns-eyebrow{font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.25em;color:var(--gold3);margin-bottom:1rem}
.sns-row{display:flex;justify-content:center;gap:32px}
.sns-link{display:flex;flex-direction:column;align-items:center;gap:6px;text-decoration:none;padding:14px;border-radius:8px;cursor:pointer;position:relative;z-index:10;min-width:60px}
.sns-label{font-size:9px;letter-spacing:0.1em;font-family:'Cinzel',serif}
.bottom{background:var(--bg2);border-top:1px solid var(--border);padding:2.5rem 1.25rem;text-align:center}
.bottom-logo{width:64px;height:64px;border-radius:50%;object-fit:cover;margin:0 auto 0.75rem;display:block;border:1px solid var(--border2);box-shadow:0 0 20px rgba(201,168,76,0.1)}
.bottom-brand{font-family:'Cinzel',serif;font-size:1rem;color:var(--gold2);letter-spacing:0.2em;margin-bottom:1.25rem}
.bottom-note{font-size:10px;color:var(--text4);letter-spacing:0.05em;margin-top:1.5rem;line-height:1.9}
</style>
</head>
